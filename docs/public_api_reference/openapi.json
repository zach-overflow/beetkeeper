  "tags": [
    {
      "name": "authentication",
      "description": "Used only when optional \"beetkeeper.auth.enable_login_protection\" is \"true\". \nRoutes for simple login / logout flows. Beetkeeper does not support multiple user identities.\nOnly handles authentication, with implicit authorization to everything for an authenticated client.\n"
    },
    {
      "name": "imports",
      "description": "Routes for managing [beets imports](https://beets.readthedocs.io/en/stable/reference/cli.html#import).\nOffer API-based import execution, import history, import choice selection, and more.\nFor automated beets setups, you will typically rely on these endpoints the most. \nThese endpoints also power the frontend import management web UI page.\n"
    },
    {
      "name": "query",
      "description": "Routes for [querying your beets library](https://beets.readthedocs.io/en/stable/reference/query.html).\nSupports API-based queries, using standard `beets` query syntax. Useful for checking the status of your\nbeets-managed library. These endpoints also power the frontend query UI page.\n"
    },
    {
      "name": "events",
      "description": "Routes pertaining to [beets events](https://beets.readthedocs.io/en/stable/dev/plugins/events.html).\nDocumented routes read-only. The [beetkeeper-plugin library](https://pypi.org/project/beetkeeper-plugin/)\nautomatically pushes beets events to the beetkeeper server. Events serve to provide a full historical\ntrace of any / all beets imports, file operations, etc. Helpful for tracing origins, or fine-tuning beets\nconfigurations, especially in automated setups.\n"
    },
    {
      "name": "monitoring",
      "description": "Routes for beetkeeper system observability, and availability checks."
    }
  ]
}
