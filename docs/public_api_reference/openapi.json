  "paths": {
    "/api/auth/login": {
      "post": {
        "tags": [
          "authentication"
        ],
        "summary": "Login",
        "description": "Exchange the configured `beetkeeper.auth` credentials for a bearer token.",
        "operationId": "login_api_auth_login_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequestBody"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponseBody"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": [
          "authentication"
        ],
        "summary": "Logout",
        "description": "Revoke the bearer token this request authenticated with (identified by the `Authorization` header).",
        "operationId": "logout_api_auth_logout_post",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LogoutResponseBody"
                }
              }
            }
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ]
      }
    },
    "/api/events": {
      "get": {
        "tags": [
          "events"
        ],
        "summary": "Events",
        "description": "Lists the requested page of ingested beets listener events (newest first), each with the beets album/track\nids of its child rows (the ones the beetkeeper event-listener plugin pushed to the POST endpoints).",
        "operationId": "events_api_events_get",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "description": "1-based page number.",
              "default": 1,
              "title": "Page"
            },
            "description": "1-based page number."
          },
          {
            "name": "page_size",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 100,
              "minimum": 1,
              "description": "Maximum results per page.",
              "default": 25,
              "title": "Page Size"
            },
            "description": "Maximum results per page."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EventsListResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/health": {
      "get": {
        "tags": [
          "monitoring"
        ],
        "summary": "Health",
        "description": "Report this process's pid, the current import leader (lock holder), and the shared job count.",
        "operationId": "health_api_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthInfo"
                }
              }
            }
          }
        }
      }
    },
    "/api/import": {
      "post": {
        "tags": [
          "imports"
        ],
        "summary": "Start Import",
        "description": "Enqueue an import of the given paths and return the created (PENDING) job.\n\nSet `quiet=true` to import non-interactively (the `beet import -q` equivalent): no decision prompts.\nThe optional per-job settings (`quiet`, `logpath`, `group_albums`, `flat`, `set_fields`) default to the\ncorresponding beets config values when left unspecified.",
        "operationId": "start_import_api_import_post",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImportSubmitRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImportJob"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "imports"
        ],
        "summary": "List Imports",
        "description": "List one page of known import jobs, newest first (so page 1 shows the most recent submissions).",
        "operationId": "list_imports_api_import_get",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "description": "1-based page number.",
              "default": 1,
              "title": "Page"
            },
            "description": "1-based page number."
          },
          {
            "name": "page_size",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 100,
              "minimum": 1,
              "description": "Maximum results per page.",
              "default": 25,
              "title": "Page Size"
            },
            "description": "Maximum results per page."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ImportJob"
                  },
                  "title": "Response List Imports Api Import Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/import/{job_id}": {
      "get": {
        "tags": [
          "imports"
        ],
        "summary": "Get Import",
        "description": "Return a single import job (poll this for status / the pending decision).",
        "operationId": "get_import_api_import__job_id__get",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImportJob"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/import/{job_id}/decision": {
      "post": {
        "tags": [
          "imports"
        ],
        "summary": "Decide Import",
        "description": "Answer the decision an import is parked on; 409 if it isn't awaiting one.",
        "operationId": "decide_import_api_import__job_id__decision_post",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImportDecision"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImportJob"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/import/{job_id}/abort": {
      "post": {
        "tags": [
          "imports"
        ],
        "summary": "Abort Import",
        "description": "Request cooperative cancellation of an in-flight import.",
        "operationId": "abort_import_api_import__job_id__abort_post",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImportJob"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/query/list": {
      "get": {
        "tags": [
          "query"
        ],
        "summary": "List ",
        "description": "Execute `beet list ...`: return one page of matching tracks (or albums) as JSON objects.\n\nArgs:\n    library: injected beets library adapter.\n    page: pagination query params (`page`, `page_size`).\n    albums: like `-a`; return albums instead of individual tracks.\n    keyword: repeatable bare-keyword query parts (substring match across default fields).\n    field: repeatable `field:value` parts (exact `=`, regex `::`, numeric/date ranges all supported).\n    phrase: a single multi-word phrase part.\n    filepath: a path within the beets library (becomes a path query).\n    sort_by: a beets sort token, e.g. `year+` or `artist-`.\n\nSee: https://beets.readthedocs.io/en/v2.12.0/reference/cli.html#list",
        "operationId": "list__api_query_list_get",
        "parameters": [
          {
            "name": "albums",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false,
              "title": "Albums"
            }
          },
          {
            "name": "keyword",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                {
                  "type": "null"
                }
              ],
              "title": "Keyword"
            }
          },
          {
            "name": "field",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                {
                  "type": "null"
                }
              ],
              "title": "Field"
            }
          },
          {
            "name": "phrase",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Phrase"
            }
          },
          {
            "name": "filepath",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "path"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Filepath"
            }
          },
          {
            "name": "sort_by",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Sort By"
            }
          },
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "description": "1-based page number.",
              "default": 1,
              "title": "Page"
            },
            "description": "1-based page number."
          },
          {
            "name": "page_size",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 100,
              "minimum": 1,
              "description": "Maximum results per page.",
              "default": 25,
              "title": "Page Size"
            },
            "description": "Maximum results per page."
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": true
                  },
                  "title": "Response List  Api Query List Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/query/stats": {
      "get": {
        "tags": [
          "query"
        ],
        "summary": "Stats",
        "description": "Execute `beet stats`: track count, total time, approximate size, and artist/album counts.\n\nSee: https://beets.readthedocs.io/en/v2.12.0/reference/cli.html#stats",
        "operationId": "stats_api_query_stats_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Stats Api Query Stats Get"
                }
              }
            }
          }
        }
      }
    },
    "/api/query/fields": {
      "get": {
        "tags": [
          "query"
        ],
        "summary": "Fields",
        "description": "Execute `beet fields`: the item/album query fields and flexible attributes available.\n\nSee: https://beets.readthedocs.io/en/v2.12.0/reference/cli.html#fields",
        "operationId": "fields_api_query_fields_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "items": {
                      "type": "string"
                    },
                    "type": "array"
                  },
                  "type": "object",
                  "title": "Response Fields Api Query Fields Get"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "APIEventType": {
        "type": "string",
        "enum": [
          "album_imported",
          "album_removed",
          "import_task_files",
          "item_imported",
          "item_removed"
        ],
        "title": "APIEventType",
        "description": "Subset of beets listener `event_type`s which the API accepts from our plugin client.\nSee also:\n    https://beets.readthedocs.io/en/stable/dev/plugins/events.html"
      },
      "DecisionRequest": {
        "properties": {
          "job_id": {
            "type": "string",
            "title": "Job Id"
          },
          "task_id": {
            "type": "string",
            "title": "Task Id"
          },
          "prompt": {
            "type": "string",
            "title": "Prompt"
          },
          "candidates": {
            "items": {
              "$ref": "#/components/schemas/ImportCandidate"
            },
            "type": "array",
            "title": "Candidates"
          },
          "allowed_actions": {
            "items": {
              "$ref": "#/components/schemas/ImportAction"
            },
            "type": "array",
            "title": "Allowed Actions"
          }
        },
        "type": "object",
        "required": [
          "job_id",
          "task_id",
          "prompt"
        ],
        "title": "DecisionRequest",
        "description": "Published when the importer needs a user choice for a task; the matching `ImportDecision` unblocks it."
      },
      "EventsListResponse": {
        "properties": {
          "events": {
            "items": {
              "$ref": "#/components/schemas/ListenerEventRecord"
            },
            "type": "array",
            "title": "Events"
          }
        },
        "additionalProperties": false,
        "type": "object",
        "title": "EventsListResponse",
        "description": "Response payload for the events listing: recently ingested listener events, newest first."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "HealthInfo": {
        "properties": {
          "process_pid": {
            "type": "integer",
            "title": "Process Pid"
          },
          "hostname": {
            "type": "string",
            "title": "Hostname"
          },
          "import_lock_holder": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Import Lock Holder"
          },
          "is_import_leader": {
            "type": "boolean",
            "title": "Is Import Leader"
          },
          "job_count": {
            "type": "integer",
            "title": "Job Count"
          }
        },
        "type": "object",
        "required": [
          "process_pid",
          "hostname",
          "import_lock_holder",
          "is_import_leader",
          "job_count"
        ],
        "title": "HealthInfo",
        "description": "Per-process health snapshot."
      },
      "ImportAction": {
        "type": "string",
        "enum": [
          "apply",
          "asis",
          "skip"
        ],
        "title": "ImportAction",
        "description": "beetkeeper-side mirror of beets' import `action` choices (decoupled from beets internals)."
      },
      "ImportCandidate": {
        "properties": {
          "index": {
            "type": "integer",
            "title": "Index"
          },
          "label": {
            "type": "string",
            "title": "Label"
          },
          "similarity": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Similarity",
            "description": "1.0 - beets match distance, if available."
          },
          "data_source": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Data Source"
          },
          "year": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Year"
          },
          "country": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Country"
          },
          "media": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Media"
          },
          "record_label": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Record Label"
          },
          "catalognum": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Catalognum"
          },
          "disambiguation": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Disambiguation"
          },
          "track_count": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Track Count"
          },
          "album_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Album Id",
            "description": "Source-specific release id (e.g. a MusicBrainz MBID)."
          },
          "release_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Release Url",
            "description": "Web URL for the release, from the source plugin (beets' `AlbumInfo.data_url`)."
          },
          "details": {
            "type": "string",
            "title": "Details",
            "description": "One-line summary of the differentiating attributes (empty string when none are known).",
            "readOnly": true
          }
        },
        "type": "object",
        "required": [
          "index",
          "label",
          "details"
        ],
        "title": "ImportCandidate",
        "description": "A serializable view of one beets match candidate, surfaced to the UI for selection.\n\nBeyond the headline `label`/`similarity`, the optional release attributes below let the UI tell\notherwise-identical candidates apart (e.g. different pressings/editions of the same album); `details`\njoins the populated ones into a single human-readable line for display."
      },
      "ImportDecision": {
        "properties": {
          "action": {
            "$ref": "#/components/schemas/ImportAction"
          },
          "candidate_index": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Candidate Index",
            "description": "Required when `action` is APPLY."
          }
        },
        "type": "object",
        "required": [
          "action"
        ],
        "title": "ImportDecision",
        "description": "The user's answer to a `DecisionRequest` (posted back from the UI)."
      },
      "ImportJob": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "status": {
            "$ref": "#/components/schemas/ImportJobStatus"
          },
          "paths": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Paths"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At"
          },
          "error": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error"
          },
          "pending_decision": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/DecisionRequest"
              },
              {
                "type": "null"
              }
            ]
          },
          "decision_submitted": {
            "type": "boolean",
            "title": "Decision Submitted",
            "default": false
          },
          "output": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Output"
          },
          "quiet": {
            "type": "boolean",
            "title": "Quiet",
            "default": false
          },
          "logpath": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Logpath"
          },
          "group_albums": {
            "type": "boolean",
            "title": "Group Albums",
            "default": false
          },
          "flat": {
            "type": "boolean",
            "title": "Flat",
            "default": false
          },
